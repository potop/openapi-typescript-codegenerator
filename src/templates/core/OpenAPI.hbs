import type { ApiRequestOptions } from './ApiRequestOptions';

type Resolver<T> = (options: ApiRequestOptions) => Promise<T>;
type Headers = Record<string, string>;

export type ApiCacheOptions = {
	enabled: boolean;
	ttl?: number;
	key?: string;
	featureToggled?: boolean;
};

export interface CacheProvider {
	getItem(key: string): Promise<string | null | undefined>;
	setItem(key: string, value: string): Promise<void>;
	removeItem?(key: string): Promise<void> | void;
	destroy?(opts?: { clearData?: boolean }): void;
}

export type OpenAPIConfig = {
	BASE: string;
	VERSION: string;
	WITH_CREDENTIALS: boolean;
	CREDENTIALS: 'include' | 'omit' | 'same-origin';
	TOKEN?: string | Resolver<string> | undefined;
	USERNAME?: string | Resolver<string> | undefined;
	PASSWORD?: string | Resolver<string> | undefined;
	HEADERS?: Headers | Resolver<Headers> | undefined;
	ENCODE_PATH?: ((path: string) => string) | undefined;
	CACHE_OPTIONS?: ApiCacheOptions | undefined;
	CACHE_PROVIDER?: CacheProvider | undefined;
	SMART_DOWNLOAD?: boolean | undefined;
	REDIRECT?: RequestRedirect | undefined;
	ON_OPAQUE_REDIRECT?: ((response: Response) => void) | undefined;
};

export const OpenAPI: OpenAPIConfig = {
	BASE: '{{{server}}}',
	VERSION: '{{{version}}}',
	WITH_CREDENTIALS: false,
	CREDENTIALS: 'include',
	TOKEN: undefined,
	USERNAME: undefined,
	PASSWORD: undefined,
	HEADERS: undefined,
	ENCODE_PATH: undefined,
	CACHE_OPTIONS: undefined,
	CACHE_PROVIDER: undefined,
	SMART_DOWNLOAD: false,
	REDIRECT: undefined,
	ON_OPAQUE_REDIRECT: undefined,
};

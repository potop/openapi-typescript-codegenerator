/**
 * Extracts a filename from an HTTP `Content-Disposition` header value.
 *
 * Handles these forms, in order of preference:
 *   1. `filename*=UTF-8''<percent-encoded>` — RFC 5987/8187 extended parameter
 *      (only the UTF-8 charset is recognized; other charsets fall through).
 *   2. `filename="..."` — quoted form (RFC 6266).
 *   3. `filename=...`   — bare token form (RFC 6266).
 *
 * Returns `'download'` as a last-resort fallback when the header is missing
 * or none of the patterns match. Non-UTF-8 extended params, multi-line
 * continuations, and other exotic RFC 6266 edge cases are intentionally not
 * handled — if that becomes necessary, swap this helper for the npm
 * `content-disposition` package.
 */
const getContentDispositionFilename = (contentDisposition: string | null): string => {
	if (!contentDisposition) return 'download';
	const utf8Match = contentDisposition.match(/filename\*=UTF-8''([^;]+)/i);
	if (utf8Match?.[1]) {
		try {
			return decodeURIComponent(utf8Match[1]);
		} catch {
			/* fall through */
		}
	}
	const quotedMatch = contentDisposition.match(/filename="([^"]+)"/i);
	if (quotedMatch?.[1]) {
		return quotedMatch[1];
	}
	const bareMatch = contentDisposition.match(/filename=([^;]+)/i);
	if (bareMatch?.[1]) {
		return bareMatch[1].trim();
	}
	return 'download';
};

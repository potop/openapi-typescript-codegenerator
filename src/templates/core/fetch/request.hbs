/**
 * Request method
 * @param config The OpenAPI configuration object
 * @param options The request options from the service
 * @returns CancelablePromise<T>
 * @throws ApiError
 */
export const request = <T>(config: OpenAPIConfig, options: ApiRequestOptions): CancelablePromise<T> => {
	return new CancelablePromise(async (resolve, reject, onCancel) => {
		try {
			const cacheProvider = config.CACHE_PROVIDER;
			const isCacheEnabled = Boolean(config.CACHE_OPTIONS?.enabled && cacheProvider);
			let cacheKey: string | undefined;
			if (isCacheEnabled && cacheProvider) {
				cacheKey = config.CACHE_OPTIONS?.key ?? JSON.stringify(options);
				try {
					const cachedResult = await cacheProvider.getItem(cacheKey);
					if (cachedResult) {
						resolve(JSON.parse(cachedResult));
						return;
					}
				} catch (cacheReadError) {
					config.ON_CACHE_ERROR?.('getItem', cacheReadError, cacheKey);
				}
			}

			const url = getUrl(config, options);
			const formData = getFormData(options);
			const body = getRequestBody(options);
			const headers = await getHeaders(config, options);

			if (!onCancel.isCancelled) {
				const isSmartDownload = Boolean(config.SMART_DOWNLOAD);
				const response = await sendRequest(config, options, url, body, formData, headers, onCancel);
				const responseBody = await getResponseBody(response, config, isSmartDownload);
				const responseHeader = getResponseHeader(response, options.responseHeader);

				const result: ApiResult = {
					url,
					ok: response.ok,
					status: response.status,
					statusText: response.statusText,
					body: responseHeader ?? responseBody,
				};

				catchErrorCodes(options, result);

				if (isCacheEnabled && cacheKey && cacheProvider) {
					try {
						await cacheProvider.setItem(cacheKey, JSON.stringify(result.body));
					} catch (cacheWriteError) {
						config.ON_CACHE_ERROR?.('setItem', cacheWriteError, cacheKey);
					}
				}

				if (isSmartDownload) {
					handleFileDownload(response, responseBody);
				}

				resolve(result.body);
			}
		} catch (error) {
			reject(error);
		}
	});
};
